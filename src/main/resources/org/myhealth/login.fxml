<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<!-- Login page layout. -->
<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="org.myhealth.controller.Login_Controller"
           style="-fx-background-color: #f4f4f4;">

    <VBox spacing="15"
          alignment="CENTER"
          maxWidth="320"
          maxHeight="320"
          prefWidth="320"
          style="
                -fx-background-color: white;
                -fx-padding: 30;
                -fx-background-radius: 15;
                -fx-border-radius: 15;
                -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 15, 0, 0, 5);
          ">

        <Label text="MyHealth Login"
               style="
                    -fx-font-size: 22px;
                    -fx-font-weight: bold;
               "/>

        <!-- User Name -->
        <TextField fx:id="username_Field"
                   promptText="Username"
                   prefHeight="40"/>

        <!-- Password -->
        <PasswordField fx:id="password_Field"
                       promptText="Password"
                       prefHeight="40"/>

        <!-- Login Button -->
        <Button text="Login"
                onAction="#handleLogin"
                prefWidth="250"
                prefHeight="40"
                style="
                    -fx-background-color: #2196F3;
                    -fx-text-fill: white;
                    -fx-font-size: 14px;
                    -fx-background-radius: 8;
                "/>

        <!-- Signup Button -->
        <Button text="Don't have an account"
                onAction="#openSignupPage"
                style="
                    -fx-background-color: transparent;
                    -fx-text-fill: #2196F3;
                    -fx-underline: true;
                "/>

        <!-- Error Message -->
        <Label fx:id="message_Label"
               wrapText="true"
               style="-fx-font-size: 13px;"/>

    </VBox>

</StackPane>