<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<!-- Dashboard Layout. -->
<StackPane xmlns:fx="http://javafx.com/fxml" fx:controller="org.myhealth.controller.Dashboard_Controller" style="-fx-background-color: #f4f4f4;">
    <VBox spacing="15"
          alignment="CENTER"
          maxWidth="360"
          maxHeight="360"
          style="
                -fx-background-color: white;
                -fx-padding: 30;
                -fx-background-radius: 15;
                -fx-border-radius: 15;
                -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 15, 0, 0, 5);
          ">

    <Label text="MyHealth Dashboard"/>

    <!-- Welcome message updated from controller -->
    <Label fx:id="welcome_label"/>
    <Button text="Edit Profile" onAction="#openEditProfile"
            prefWidth="250"
            prefHeight="40"
            style="
                    -fx-background-color: #2196F3;
                    -fx-text-fill: white;
                    -fx-font-size: 14px;
                    -fx-background-radius: 8;"
    />
    <Button text="Health Record"
            onAction="#openHealthRecords"
            prefWidth="250"
            prefHeight="40"
            style="
                    -fx-background-color: #2196F3;
                    -fx-text-fill: white;
                    -fx-font-size: 14px;
                    -fx-background-radius: 8;"
    />
    <Button text="Log Out"
            onAction="#handleLogout"
            prefWidth="250"
            prefHeight="40"
            style="
                    -fx-background-color: #2196F3;
                    -fx-text-fill: white;
                    -fx-font-size: 14px;
                    -fx-background-radius: 8;"
    />
    <!-- Shows current health record status -->
        <Label fx:id="recordCount_Label"/>

</VBox>

</StackPane>