<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="org.myhealth.controller.HealthRecords_Controller"
           style="-fx-background-color: #f4f4f4;">

    <VBox spacing="12"
          alignment="CENTER"
          maxWidth="720"
          style="
                -fx-background-color: white;
                -fx-padding: 25;
                -fx-background-radius: 15;
                -fx-border-radius: 15;
                -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 15, 0, 0, 5);
          ">

        <Label text="Health Records"
               style="-fx-font-size: 22px; -fx-font-weight: bold;"/>

        <TextField fx:id="weight_Field"
                   promptText="Weight (kg)"
                   prefHeight="35"
                   prefWidth="350"/>

        <TextField fx:id="temperature_Field"
                   promptText="Temperature (°C)"
                   prefHeight="35"
                   prefWidth="350"/>

        <TextField fx:id="bloodPressure_Field"
                   promptText="Blood Pressure (mmHg), example: 120/80"
                   prefHeight="35"
                   prefWidth="350"/>

        <TextArea fx:id="note_Area"
                  promptText="Short note: less than 50 words and less than 250 characters"
                  prefRowCount="3"
                  prefWidth="350"/>

        <HBox spacing="10" alignment="CENTER">
            <Button text="Add Record"
                    onAction="#handleAddRecord"
                    prefWidth="130"
                    prefHeight="40"
                    style="
                        -fx-background-color: #4CAF50;
                        -fx-text-fill: white;
                        -fx-font-size: 14px;
                        -fx-background-radius: 8;
                    "/>

            <Button text="Edit Selected"
                    onAction="#handleEditRecord"
                    prefWidth="130"
                    prefHeight="40"
                    style="
                        -fx-background-color: #2196F3;
                        -fx-text-fill: white;
                        -fx-font-size: 14px;
                        -fx-background-radius: 8;
                    "/>

            <Button text="Delete Selected"
                    onAction="#handleDeleteRecord"
                    prefWidth="130"
                    prefHeight="40"
                    style="
                        -fx-background-color: #F44336;
                        -fx-text-fill: white;
                        -fx-font-size: 14px;
                        -fx-background-radius: 8;
                    "/>

            <Button text="Export Records"
                    onAction="#handleExportRecords"
                    prefWidth="130"
                    prefHeight="40"
                    style="
                        -fx-background-color: #FFC107;
                        -fx-text-fill: black;
                        -fx-font-size: 14px;
                        -fx-background-radius: 8;
                    "/>

            <Button text="Back"
                    onAction="#goBack_Dashboard"
                    prefWidth="130"
                    prefHeight="40"
                    style="
                        -fx-background-color: #607D8B;
                        -fx-text-fill: white;
                        -fx-font-size: 14px;
                        -fx-background-radius: 8;
                    "/>
        </HBox>

        <TableView fx:id="records_Table" prefHeight="230" prefWidth="680">
            <columns>
                <TableColumn fx:id="date_Column" text="Date" prefWidth="100"/>
                <TableColumn fx:id="weight_Column" text="Weight (kg)" prefWidth="100"/>
                <TableColumn fx:id="temperature_Column" text="Temp (°C)" prefWidth="110"/>
                <TableColumn fx:id="bloodPressure_Column" text="BP (mmHg)" prefWidth="130"/>
                <TableColumn fx:id="note_Column" text="Note" prefWidth="240"/>
            </columns>
        </TableView>

        <Label fx:id="message_Label"
               wrapText="true"
               style="-fx-font-size: 13px;"/>

    </VBox>

</StackPane>